# GoldScalperPro Telegram Control Panel — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ───────────────────────────────────────────────────────────────

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (find it with @userinfobot)
TELEGRAM_OWNER_ID=123456789

# ── Optional ───────────────────────────────────────────────────────────────

# Comma-separated admin Telegram IDs
TELEGRAM_ADMIN_IDS=

# Encryption key for credential storage (REQUIRED — panel refuses to start without this)
# Generate: python -m telegram_panel.main --generate-key
# Then paste the output below. Never share or commit this key.
PANEL_ENCRYPTION_KEY=PASTE_YOUR_GENERATED_FERNET_KEY_HERE

# Path to JSON config file (alternative to env vars)
# PANEL_CONFIG_FILE=telegram_panel/config/panel.json

# Database path
# PANEL_DB_PATH=telegram_panel/storage/data/panel.db

# Robot state file paths (the robot writes these; panel reads them)
# ROBOT_STATE_PATH=robot_state.json
# ROBOT_CONFIG_PATH=robot_config.json
# ROBOT_LOG_PATH=logs/robot.log

# Interface mode: file | http | socket
# ROBOT_INTERFACE_MODE=file

# MT5 connection (optional, for direct MT5 integration)
# MT5_HOST=127.0.0.1
# MT5_PORT=18812

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# Panel log path
# PANEL_LOG_PATH=telegram_panel/storage/data/logs/panel.log

# Enable debug mode
# DEBUG=0
