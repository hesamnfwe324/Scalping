{
  "_comment": "GoldScalperPro Telegram Panel Configuration",
  "_note": "Copy this file to panel.json and fill in your values. NEVER commit panel.json to version control.",

  "telegram": {
    "bot_token": "YOUR_BOT_TOKEN_FROM_BOTFATHER",
    "owner_id": 123456789,
    "admin_ids": []
  },

  "database": {
    "path": "telegram_panel/storage/data/panel.db"
  },

  "security": {
    "encryption_key": "RUN: python -m telegram_panel.main --generate-key",
    "session_timeout_minutes": 60,
    "rate_limit_window_seconds": 60,
    "rate_limit_max_requests": 30
  },

  "robot": {
    "config_path": "robot_config.json",
    "state_path": "robot_state.json",
    "log_path": "logs/robot.log",
    "interface_mode": "file",
    "heartbeat_interval_seconds": 30
  },

  "mt5": {
    "host": "127.0.0.1",
    "port": 18812,
    "timeout_seconds": 10
  },

  "logging": {
    "level": "INFO",
    "path": "telegram_panel/storage/data/logs/panel.log"
  }
}
