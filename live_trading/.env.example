# GoldScalperPro v4 — Live Trading Engine Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# For Render deployment, set these in the Render dashboard → Environment tab.

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED — MetaAPI Credentials
# ══════════════════════════════════════════════════════════════════════════════

# Your MetaAPI cloud API token
# Get it from: https://app.metaapi.cloud → API → Copy token
METAAPI_TOKEN=your_metaapi_token_here

# Your MetaAPI account ID (links to your MT5 broker account)
# Get it from: https://app.metaapi.cloud → Accounts → Copy Account ID
METAAPI_ACCOUNT_ID=your_metaapi_account_id_here

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Trading Parameters (defaults shown)
# ══════════════════════════════════════════════════════════════════════════════

# Instrument to trade
SYMBOL=XAUUSD

# Risk per trade as % of account balance
RISK_PERCENT=1.0

# Minimum signal confirmations required (3 or 4)
MIN_CONFIRMATIONS=3

# ══════════════════════════════════════════════════════════════════════════════
# STRONGLY RECOMMENDED — Risk Guardian Circuit Breakers
# Review these values carefully. They are active even at their defaults.
# ══════════════════════════════════════════════════════════════════════════════

# Halt trading if intraday PnL falls below this % of session-open balance.
# Resets automatically at UTC midnight.
DAILY_LOSS_LIMIT_PCT=3.0

# Halt trading if live equity drops more than this % below the session equity peak.
# Does NOT auto-reset — requires /reset_guardian in the Telegram panel.
MAX_DRAWDOWN_PCT=8.0

# Maximum allowed slippage for market orders (in broker points).
# 30 points ≈ $0.30 on XAUUSD with a standard 5-digit broker.
# Increase to 50 during high-volatility periods (news events).
SLIPPAGE_POINTS=30

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — File Paths
# For cloud deployments with a persistent volume, override these to point to
# the mounted volume directory (e.g. /data/robot_state.json).
# ══════════════════════════════════════════════════════════════════════════════

# STATE_FILE=robot_state.json
# MT5_SNAPSHOT=robot_mt5_snapshot.json
# COMMANDS_FILE=robot_commands.json
# LOG_FILE=live_trading/robot.log

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED ON RENDER — Redis for cross-service IPC
# ══════════════════════════════════════════════════════════════════════════════
# When robot and panel run as separate Render services they have separate
# filesystems and CANNOT share JSON files. Redis bridges this gap.
# On Render: this is set automatically via `fromService` in render.yaml.
# Locally: leave empty to use file-based IPC (both services on same machine).
#
# REDIS_URL=redis://localhost:6379

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED ON RENDER — Persistent disk paths
# ══════════════════════════════════════════════════════════════════════════════
# State files are written to /data (mounted persistent disk on Render).
# Locally, remove these overrides to use the defaults (project-relative paths).
STATE_FILE=/data/robot_state.json
MT5_SNAPSHOT=/data/robot_mt5_snapshot.json
COMMANDS_FILE=/data/robot_commands.json
GUARDIAN_STATE_FILE=/data/guardian_state.json
LOG_FILE=/data/robot.log
